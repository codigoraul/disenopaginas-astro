Redirect 301 /sitios-autoadministrables.php /servicios/sitios-web-autoadministrables
Redirect 301 /cms.php /servicios/sitios-web-autoadministrables
Redirect 301 /maquetacion-figma.php /servicios/maquetacion-web-figma
Redirect 301 /paginas-rapidas.php /servicios/paginas-rapida-astro
Redirect 301 /web-tienda-online.php /productos-online/
Redirect 301 /tienda-online/ /productos-online/
Redirect 301 /diseno-web-abogados.php /diseno-web-abogados
Redirect 301 /abogados.php /diseno-web-abogados
Redirect 301 /diseno-web-clinicas.php /diseno-web-clinicas-dentales
Redirect 301 /clinicas.php /diseno-web-clinicas-dentales
Redirect 301 /dentistas.php /diseno-web-clinicas-dentales
Redirect 301 /diseno-web-turismo.php /diseno-web-turismo
Redirect 301 /turismo.php /diseno-web-turismo
Redirect 301 /diseno-web-mineria.php /diseno-web-empresas-mineria
Redirect 301 /mineria.php /diseno-web-empresas-mineria
