  </section>

  <!-- ══ STATS ══ -->
  <div class="stats-bar">
    <div class="container">
      <div class="row g-0">
        <div class="col-6 col-md-3 stat-cell" style="border-right:1px solid var(--border);">
          <span class="stat-num">+120</span>
