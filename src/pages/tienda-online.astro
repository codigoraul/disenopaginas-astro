  <style>
    *, *::before, *::after { box-sizing: border-box; }
    html { scroll-behavior: smooth; }
    body {
      font-family: 'Inter', system-ui, sans-serif;
      font-size: 16px;
      color: #6B7280;
      background: #fff;
      margin: 0;
      -webkit-font-smoothing: antialiased;
    }
    :root {
      --navy: #0045A7;
      --blue: #0045A7;
      --blue-hover: #003380;
      --soft: #6B7280;
      --muted: #9CA3AF;
      --light: #F9FAFB;
      --border: #E5E7EB;
    }
    h1, h2, h3, h4, h5 { color: var(--navy); font-weight: 700; line-height: 1.2; }

    /* ── NAVBAR ── */
    .site-nav {
      position: sticky; top: 0; z-index: 200;
      background: rgba(255,255,255,0.97);
      backdrop-filter: blur(12px);
      border-bottom: 1px solid var(--border);
    }
    .nav-inner {
      display: flex; align-items: center; justify-content: space-between;
      padding: .9rem 0; gap: 1rem;
    }
    .nav-logo { font-weight: 800; font-size: 1.1rem; color: var(--navy); text-decoration: none; }
    .nav-logo span { color: var(--blue); }
    .nav-logo img { display: block; }
    .nav-links { display: flex; align-items: center; gap: .2rem; list-style: none; margin: 0; padding: 0; }
    .nav-links a {
      text-decoration: none; color: var(--soft); font-size: .875rem; font-weight: 500;
      padding: .4rem .75rem; border-radius: 8px; transition: color .15s, background .15s;
    }
    .nav-links a:hover { color: var(--blue); background: #EFF6FF; }
    .nav-cta { background: var(--blue) !important; color: white !important; border-radius: 10px; }
    .nav-cta:hover { opacity: .9; }
    .nav-toggle { display: none; background: none; border: 1px solid var(--border); border-radius: 8px; padding: .4rem .6rem; cursor: pointer; color: var(--navy); }
    @media (max-width: 900px) {
      .nav-links { display: none; flex-direction: column; align-items: flex-start; position: absolute; top: 100%; left: 0; right: 0; background: white; border-bottom: 1px solid var(--border); padding: 1rem; gap: .2rem; box-shadow: 0 8px 20px rgba(0,0,0,.06); }
      .nav-links.open { display: flex; }
      .nav-toggle { display: block; }
      .site-nav { position: relative; }
    }

    /* ── HERO SLIDER ── */
    .hero-section {
      position: relative; height: 680px;
      overflow: hidden; color: #fff;
      display: flex; align-items: center;
    }
    /* Cada slide tiene su propia imagen de fondo */
    .swiper-slide {
      display: none; opacity: 0; transition: opacity .6s ease;
      position: absolute; inset: 0;
    }
    .swiper-slide-active { display: block; opacity: 1; }
    .slide-img {
      position: absolute; inset: 0; width: 100%; height: 100%;
      object-fit: cover; object-position: center;
    }
    .slide-overlay {
      position: absolute; inset: 0;
      background: linear-gradient(to right, rgba(1,20,55,.75) 40%, rgba(1,20,55,.35) 100%);
    }
    .hero-content {
      position: relative; z-index: 3; width: 100%;
      display: flex; align-items: center; height: 100%;
      padding-top: 80px;
    }
    .hero-swiper { position: relative; width: 100%; height: 100%; }
    .swiper-wrapper { position: relative; width: 100%; height: 100%; }
    .hero-main-title {
      font-size: clamp(1.9rem, 3.5vw, 2.9rem);
      font-weight: 800; color: #fff !important; line-height: 1.15; margin-bottom: 1rem;
    }
    .hero-subtitle {
      font-size: .85rem; color: #AEF8FF !important;
      font-weight: 700; text-transform: uppercase; letter-spacing: 1.5px; margin-bottom: 1rem;
    }
    .slide-body { position: relative; z-index: 2; padding: 2rem 0; }
    .slide-text { font-size: .975rem; line-height: 1.8; margin-bottom: 1.5rem; color: rgba(255,255,255,.88); }
    .hero-titles-container { display: flex; flex-direction: column; justify-content: center; }
    .hero-pagination {
      position: absolute; bottom: 28px; left: 50%; transform: translateX(-50%);
      display: flex; gap: 10px; z-index: 10;
    }
    .swiper-pagination-bullet {
      width: 10px; height: 10px; background: rgba(255,255,255,.35);
      border-radius: 50%; cursor: pointer; transition: all .3s ease;
      border: 1.5px solid rgba(255,255,255,.3);
    }
    .swiper-pagination-bullet-active { background: #AEF8FF; transform: scale(1.3); border-color: #AEF8FF; }
    @media (max-width: 768px) {
      .hero-section { height: 100svh; min-height: 580px; }
      .slide-overlay { background: rgba(1,20,55,.65); }
    }

    /* ── STATS ── */
    .stats-bar { background: white; border-top: 1px solid var(--border); border-bottom: 1px solid var(--border); }
    .stat-cell { text-align: center; padding: 2rem 1rem; }
    .stat-num { font-size: 40px; font-weight: 800; color: var(--blue); line-height: 1; display: block; letter-spacing: -.02em; }
    .stat-lbl { font-size: 14px; color: var(--muted); margin-top: .4rem; display: block; }

    /* ── LABELS / TITLES ── */
    .section-label {
      display: inline-block; background: none; color: #39ceee;
      font-size: 12px; font-weight: 700; letter-spacing: 2px; text-transform: uppercase;
      margin-bottom: .75rem; padding: 0; border: none;
    }
    .section-title {
      font-size: 36px; font-weight: 700;
      color: var(--navy); margin-bottom: .9rem; line-height: 40px;
    }
    .section-sub { font-size: 16px; color: var(--soft); max-width: 600px; margin: 0 auto; line-height: 1.7; }

    /* ── SERVICIOS ── */
    .serv-card {
      background: white; border: 1px solid var(--border); border-radius: 20px;
      padding: 2.25rem 2rem; height: 100%;
      transition: box-shadow .2s, transform .2s;
    }
    .serv-card:hover { box-shadow: 0 16px 40px rgba(37,99,235,.12); transform: translateY(-4px); }
    .serv-card.featured { border-color: var(--blue); border-width: 2px; position: relative; }
    .serv-badge {
      position: absolute; top: -14px; left: 50%; transform: translateX(-50%);
      background: var(--blue); color: white; font-size: .78rem; font-weight: 700;
      padding: .35rem 1.1rem; border-radius: 999px; white-space: nowrap;
    }
    .serv-img { width: 100%; height: 180px; object-fit: cover; border-radius: 12px; margin-bottom: 1.5rem; }
    .serv-card h3 { font-size: 18px; font-weight: 700; color: var(--navy); margin-bottom: .75rem; line-height: 28px; }
    .serv-card p { font-size: 15px; color: var(--soft); margin-bottom: 1.1rem; line-height: 1.7; }
    .feat-list { list-style: none; padding: 0; margin: 0 0 1.75rem; }
    .feat-list li { font-size: 14px; color: #374151; padding: .35rem 0; display: flex; align-items: center; gap: .6rem; }
    .feat-list li i { color: var(--blue); font-size: 1rem; flex-shrink: 0; }
    .serv-tag { display: inline-block; background: #EFF6FF; color: var(--blue); font-size: 12px; font-weight: 700; letter-spacing: .8px; text-transform: uppercase; padding: 3px 10px; border-radius: 999px; margin-bottom: 1rem; }

    /* ── PORTAFOLIO ── */
    .port-card {
      background: white; border: 1px solid var(--border); border-radius: 18px;
      overflow: hidden; height: 100%;
      transition: box-shadow .2s, transform .2s;
    }
    .port-card:hover { box-shadow: 0 16px 40px rgba(0,0,0,.1); transform: translateY(-4px); }
    .port-card img { width: 100%; height: 210px; object-fit: cover; }
    .port-body { padding: 1.35rem 1.5rem 1.6rem; }
    .port-cat { font-size: 12px; color: var(--blue); font-weight: 700; text-transform: uppercase; letter-spacing: 1.2px; margin-bottom: .4rem; }
    .port-body h4 { font-size: 18px; font-weight: 700; color: var(--navy); margin-bottom: .4rem; line-height: 26px; }
    .port-body p { font-size: 14px; color: var(--muted); margin-bottom: .9rem; line-height: 1.6; }
    .port-tags { display: flex; gap: .4rem; flex-wrap: wrap; margin-bottom: .9rem; }
    .port-tag-item { background: #EFF6FF; color: var(--blue); font-size: 12px; font-weight: 600; padding: 3px 10px; border-radius: 999px; }
    .port-link { font-size: 14px; font-weight: 700; color: var(--blue); text-decoration: none; }
    .port-link:hover { text-decoration: underline; }
    .port-bar { display: flex; gap: 5px; align-items: center; padding: .55rem .85rem; background: #F8FAFC; }
    .dot { width: 10px; height: 10px; border-radius: 50%; }

    /* ── VENTAJAS ── */
    .adv-item {
      display: flex; gap: 1.25rem; align-items: flex-start;
      padding: 1.6rem; background: white; border: 1px solid var(--border);
      border-radius: 16px; height: 100%;
      transition: box-shadow .2s;
    }
    .adv-item:hover { box-shadow: 0 8px 24px rgba(37,99,235,.08); }
    .adv-icon {
      width: 48px; height: 48px; background: #EFF6FF; border-radius: 12px;
      display: flex; align-items: center; justify-content: center;
      color: var(--blue); font-size: 1.4rem; flex-shrink: 0; margin-top: .1rem;
    }
    .adv-item h4 { font-size: 18px; font-weight: 700; color: var(--navy); margin-bottom: .4rem; }
    .adv-item p { font-size: 15px; color: var(--soft); margin: 0; line-height: 1.65; }

    /* ── PROCESO ── */
    .step { background: white; border: 1px solid var(--border); border-radius: 18px; padding: 2.5rem 1.75rem; text-align: center; height: 100%; }
    .step-n { width: 58px; height: 58px; display: inline-flex; align-items: center; justify-content: center; background: var(--blue); color: white; border-radius: 50%; font-weight: 800; font-size: 1.3rem; margin-bottom: 1.4rem; }
    .step h3 { font-size: 18px; font-weight: 700; color: var(--navy); margin-bottom: .6rem; }
    .step p { font-size: 15px; color: var(--soft); margin: 0; line-height: 1.7; }

    /* ── CTA ── */
    .cta-box { background: linear-gradient(135deg, #1E3A5F 0%, #1D4ED8 100%); border-radius: 24px; padding: 4rem 2rem; text-align: center; }
    .cta-box h2 { color: white; font-size: 30px; font-weight: 700; margin-bottom: .75rem; line-height: 36px; }
    .cta-box p { color: rgba(255,255,255,.8); font-size: 16px; margin-bottom: 2rem; }

    /* ── FORM ── */
    .form-box { background: white; border: 1px solid var(--border); border-radius: 20px; padding: 2.5rem; box-shadow: 0 4px 24px rgba(0,0,0,.05); }
    .form-label { font-size: .82rem; font-weight: 600; color: var(--navy); margin-bottom: .35rem; }
    .form-control, .form-select { border-color: var(--border); border-radius: 10px; font-size: .875rem; padding: .65rem 1rem; color: #374151; }
    .form-control:focus, .form-select:focus { border-color: var(--blue); box-shadow: 0 0 0 3px rgba(37,99,235,.1); }

    /* ── BUTTONS ── */
    .btn-main { display: inline-flex; align-items: center; gap: .5rem; background: var(--blue); color: white; text-decoration: none; border: none; border-radius: 12px; padding: .8rem 1.75rem; font-weight: 700; font-size: .9rem; transition: opacity .2s, transform .15s; cursor: pointer; }
    .btn-main:hover { opacity: .9; color: white; transform: translateY(-1px); }
    .btn-ghost { display: inline-flex; align-items: center; gap: .5rem; background: white; color: var(--navy); text-decoration: none; border: 1.5px solid var(--border); border-radius: 12px; padding: .8rem 1.75rem; font-weight: 600; font-size: .9rem; transition: border-color .2s; }
    .btn-ghost:hover { border-color: var(--blue); color: var(--blue); }
    .btn-full { width: 100%; justify-content: center; padding: .9rem; font-size: .95rem; }

    /* ── FAQ ── */
    .faq-wrap { background: white; border: 1px solid var(--border); border-radius: 12px; margin-bottom: .6rem; overflow: hidden; }
    .faq-wrap .accordion-button { font-size: 16px; font-weight: 600; color: var(--navy); padding: 1.35rem 1.6rem; background: white; }
    .faq-wrap .accordion-button:not(.collapsed) { background: #EFF6FF; color: var(--blue); box-shadow: none; }
    .faq-wrap .accordion-button:focus { box-shadow: none; }
    .faq-wrap .accordion-body { font-size: 15px; color: var(--soft); padding: 1rem 1.6rem 1.4rem; line-height: 1.8; }

    /* ── COMPARE ── */
    .cmp-table { border-radius: 16px; overflow: hidden; box-shadow: 0 4px 20px rgba(0,0,0,.06); width: 100%; }
    .cmp-table th { background: var(--navy); color: white; padding: .9rem 1.25rem; font-size: .85rem; font-weight: 600; border: none; }
    .cmp-table th.hl { background: var(--blue); }
    .cmp-table td { padding: .8rem 1.25rem; border-color: var(--border); font-size: .85rem; vertical-align: middle; }
    .good { color: var(--blue); font-weight: 700; }
    .ok { color: #16A34A; font-weight: 600; }
    .bad { color: var(--muted); }
  </style>
</head>
<body>

  <!-- ══ NAVBAR ══ -->
  <nav class="site-nav">
    <div class="container">
      <div class="nav-inner">
        <a href="/" class="nav-logo">
          <img src="/assets/img/tienda-online/logo.svg" alt="DiseñoPaginas.cl" width="140" height="53" style="height:40px;width:auto;" />
        </a>
        <ul class="nav-links" id="navLinks">
          <li><a href="#servicios">Servicios</a></li>
