      font-size: 14px !important; text-decoration: none; color: #DDDEDC !important;
    }
    .footer-bottom-nav a:hover { color: #35A3EA !important; }
    @media (max-width: 768px) {
      .footer-bottom-nav { justify-content: flex-start; margin-top: .5rem; }
    }
  </style>
  <Footer />

  <script src="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.3/js/bootstrap.bundle.min.js" crossorigin="anonymous"></script>
  <script>
    // ── Navbar hamburguesa
    const toggle = document.getElementById('navToggle');
    const navLinks = document.getElementById('navLinks');
    toggle?.addEventListener('click', () => navLinks?.classList.toggle('open'));
    navLinks?.querySelectorAll('a').forEach(a => a.addEventListener('click', () => navLinks.classList.remove('open')));

    // ── Hero Slider
    document.addEventListener('DOMContentLoaded', function () {
      const slides     = document.querySelectorAll('.hero-swiper .swiper-slide');
      const pagination = document.querySelector('.hero-pagination');
      let current = 0, timer;

      if (pagination) {
        pagination.innerHTML = '';
        slides.forEach((_, i) => {
          const b = document.createElement('span');
          b.className = 'swiper-pagination-bullet';
          b.addEventListener('click', () => { current = i; show(i); restart(); });
          pagination.appendChild(b);
        });
      }

      function show(idx) {
        const bullets = document.querySelectorAll('.hero-pagination .swiper-pagination-bullet');
        slides.forEach(s  => s.classList.remove('swiper-slide-active'));
        bullets.forEach(b => b.classList.remove('swiper-pagination-bullet-active'));
        if (slides[idx])  slides[idx].classList.add('swiper-slide-active');
        if (bullets[idx]) bullets[idx].classList.add('swiper-pagination-bullet-active');
      }

      function next() { current = (current + 1) % slides.length; show(current); }
      function restart() { clearInterval(timer); timer = setInterval(next, 5000); }

      setTimeout(() => { show(0); if (slides.length > 1) restart(); }, 100);
    });
  </script>

</body>
</html>
