        <button class="nav-toggle" id="navToggle" aria-label="Abrir menú">
          <i class="ti ti-menu-2"></i>
        </button>
      </div>
    </div>
  </nav>

  <!-- ══ HERO SLIDER ══ -->
  <section class="hero-section" id="inicio" aria-label="Hero tienda online Chile">
    <div class="hero-swiper">
      <div class="swiper-wrapper">

        <!-- Slide 1 — imagen slider-1.webp de diseñopaginas.cl/tienda-online/ -->
        <div class="swiper-slide">
          <img src="/assets/img/tienda-online/slider-1.webp" alt="Tienda online Chile con carrito de compras WooCommerce" class="slide-img" />
          <div class="slide-overlay"></div>
          <div class="slide-body container">
            <div class="row align-items-center" style="min-height:580px;">
              <div class="col-12 col-lg-6">
                <p class="hero-subtitle">Tienda Online Chile</p>
                <h1 class="hero-main-title">Tu tienda online Chile<br/><em style="font-style:normal;color:#AEF8FF;">vende por internet hoy</em></h1>
