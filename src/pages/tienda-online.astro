                  <a href="#servicios" class="btn border-2 btn-outline-light fw-bold">Quiero mi tienda online <i class="ti ti-arrow-up-right"></i></a>
                  <a href="#contacto" class="btn border-2 btn-outline-light">Cotizar ahora</a>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Slide 2 — imagen slider-2.webp -->
        <div class="swiper-slide">
          <img src="/assets/img/tienda-online/slider-2.webp" alt="WooCommerce Chile ecommerce con Webpay Plus carrito de compras" class="slide-img" />
          <div class="slide-overlay"></div>
          <div class="slide-body container">
            <div class="row align-items-center" style="min-height:580px;">
              <div class="col-12 col-lg-6">
                <p class="hero-subtitle">Tienda Online</p>
                <h2 class="hero-main-title">Vende 24/7 con tu<br/><em style="font-style:normal;color:#AEF8FF;">e-commerce propio</em></h2>
                <p class="slide-text">Tiendas <strong>WooCommerce</strong> con pasarela de pago chilena (<strong>Webpay Plus</strong>), gestión de productos y diseño a medida para tu marca.</p>
                <div class="d-flex gap-3 flex-wrap">
                  <a href="#servicios" class="btn border-2 btn-outline-light fw-bold">Quiero mi tienda <i class="ti ti-arrow-up-right"></i></a>
                  <a href="#contacto" class="btn border-2 btn-outline-light">Cotizar ahora</a>
                </div>
