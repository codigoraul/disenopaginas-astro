---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Página no encontrada - Diseño Páginas Chile">
  <section class="error-404-section">
    <div class="container">
      <div class="row">
        <div class="col-lg-12">
          <div class="error-404-content text-center">
            <h1 class="error-code">404</h1>
            <h2 class="error-title">Página No Encontrada</h2>
            <p class="error-description">
              Lo sentimos, la página que buscas no existe o ha sido movida.
            </p>
            <div class="error-actions">
              <a href="/" class="btn btn-primary">Ir al Inicio</a>
              <a href="/portafolio" class="btn btn-outline-primary">Ver Portafolio</a>
              <a href="/contacto" class="btn btn-outline-primary">Contacto</a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  .error-404-section {
    padding: 100px 0;
    min-height: 80vh;
    display: flex;
    align-items: center;
  }
  
  .error-404-content {
    max-width: 600px;
    margin: 0 auto;
  }
  
  .error-code {
    font-size: 120px;
    font-weight: 700;
    color: #011C42;
    line-height: 1;
    margin-bottom: 20px;
  }
  
  .error-title {
    font-size: 36px;
    font-weight: 600;
    color: #0B100F;
    margin-bottom: 20px;
  }
  
  .error-description {
    font-size: 18px;
    color: #767586;
    margin-bottom: 40px;
  }
  
  .error-actions {
    display: flex;
    gap: 15px;
    justify-content: center;
    flex-wrap: wrap;
  }
  
  .btn {
    padding: 12px 30px;
    font-size: 16px;
    font-weight: 500;
    border-radius: 5px;
    text-decoration: none;
    display: inline-block;
    transition: all 0.3s ease;
  }
  
  .btn-primary {
    background-color: #011C42;
    color: white;
    border: 2px solid #011C42;
  }
  
  .btn-primary:hover {
    background-color: transparent;
    color: #011C42;
  }
  
  .btn-outline-primary {
    background-color: transparent;
    color: #011C42;
    border: 2px solid #011C42;
  }
  
  .btn-outline-primary:hover {
    background-color: #011C42;
    color: white;
  }
  
  @media (max-width: 768px) {
    .error-404-section {
      padding: 60px 0;
    }
    
    .error-code {
      font-size: 80px;
    }
    
    .error-title {
      font-size: 28px;
    }
    
    .error-description {
      font-size: 16px;
    }
    
    .error-actions {
      flex-direction: column;
      align-items: center;
    }
    
    .btn {
      width: 200px;
    }
  }
</style>
