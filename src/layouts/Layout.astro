---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { getAssetPath, getCssPath, getJsPath, getImagePath } from '../utils/assetPath';

export interface BreadcrumbItem {
  name: string;
  url: string;
}

export interface Props {
  title: string;
  description?: string;
  keywords?: string;
  canonical?: string;
  breadcrumbs?: BreadcrumbItem[];
}

const { title= "Diseño Web Chile, Diseño páginas web Chile, Páginas Web Chile", description = "Diseño de páginas web en Chile para empresas de todos los tamaños. Más de 13 años de experiencia creando sitios web optimizados con SEO para atraer más clientes y potenciar tus servicios o productos", keywords, canonical, breadcrumbs } = Astro.props;

const baseUrl = import.meta.env.BASE_URL || '';
const currentUrl = canonical || `https://diseñopaginas.cl${Astro.url.pathname}`;
---

<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="description" content={description}>
  {keywords && <meta name="keywords" content={keywords}>}

  <!-- ===== OPEN GRAPH ===== -->
  <meta property="og:type" content="website" />
  <meta property="og:url" content={currentUrl} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content="https://diseñopaginas.cl/assets/img/og-image.jpg" />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:locale" content="es_CL" />
  <meta property="og:site_name" content="DiseñoPaginas.cl" />

  <!-- ===== TWITTER / X ===== -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:site" content="@raulriquelme2" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content="https://diseñopaginas.cl/assets/img/og-image.jpg" />

  <!-- Canonical URL -->
  <link rel="canonical" href={currentUrl} />

  <!-- Title & Favicon -->
  <title>{title}</title>
  <link rel="icon" type="image/x-icon" href={getAssetPath('/favicon.ico')}>
  <link rel="shortcut icon" href={getAssetPath('/favicon.ico')} type="image/x-icon">
  <link rel="apple-touch-icon" href={getAssetPath('/favicon.ico')}>

  <!-- Preload imagen hero LCP para mobile -->
  <link rel="preload" as="image" href="/assets/img/blog/ia-diseno-web-experto-humano/portada.webp" fetchpriority="high" media="(max-width: 991px)">

  <!-- Preconnect solo los críticos -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>

  <!-- Preload fuente crítica para LCP -->
  <link rel="preload" href="https://fonts.gstatic.com/s/inter/v13/UcCO3FwrK3iLTeHuS_fvQtMwCp50KnMw2boKoduKmMEVuLyfAZ9hiA.woff2" as="font" type="font/woff2" crossorigin>

  <!-- CSS CRÍTICO: Bootstrap + estilos base - carga síncrona para evitar FOUC -->
  <link rel="stylesheet" href={getCssPath('bootstrap.min.css')}>
  <link rel="stylesheet" href={getCssPath('style.css')}>
  <link rel="stylesheet" href={getCssPath('custom-colors.css')}>

  <!-- CSS NO CRÍTICO: diferido para no bloquear render -->
  <link rel="preload" href={getCssPath('animate.css')} as="style" onload="this.onload=null;this.rel='stylesheet'">
  <link rel="preload" href="/assets/css/tabler-icons.min.css" as="style" onload="this.onload=null;this.rel='stylesheet'">
  <link rel="preload" href={getCssPath('swiper-bundle.min.css')} as="style" onload="this.onload=null;this.rel='stylesheet'">
  <link rel="preload" href={getCssPath('hero-colors.css')} as="style" onload="this.onload=null;this.rel='stylesheet'">

  <!-- Fallback sin JS -->
  <noscript>
    <link rel="stylesheet" href={getCssPath('animate.css')}>
    <link rel="stylesheet" href="/assets/css/tabler-icons.min.css">
    <link rel="stylesheet" href={getCssPath('swiper-bundle.min.css')}>
    <link rel="stylesheet" href={getCssPath('hero-colors.css')}>
  </noscript>

  <!-- Google Fonts diferido con display=swap para evitar CLS -->
  <link rel="preload" href="https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,100..900;1,14..32,100..900&family=Outfit:wght@100..900&display=swap" as="style" onload="this.onload=null;this.rel='stylesheet'">
  <noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,100..900;1,14..32,100..900&family=Outfit:wght@100..900&display=swap"></noscript>

  <!-- Font display swap para evitar CLS con tabler-icons -->
  <style>
    @font-face {
      font-family: 'tabler-icons';
      src: url('/assets/fonts/tabler-icons.woff2?v3.31.0') format('woff2');
      font-display: swap;
      font-weight: normal;
      font-style: normal;
    }
  </style>

  <!-- Schema LocalBusiness + Person — E-E-A-T y autoridad -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "WebSite",
        "@id": "https://diseñopaginas.cl/#website",
        "url": "https://diseñopaginas.cl/",
        "name": "DiseñoPaginas.cl",
        "description": "Diseño de páginas web profesionales en Chile",
        "inLanguage": "es-CL",
        "publisher": {
          "@id": "https://diseñopaginas.cl/#negocio"
        }
      },
      {
        "@type": "LocalBusiness",
        "@id": "https://diseñopaginas.cl/#negocio",
        "name": "DiseñoPaginas.cl",
        "legalName": "DiseñoPaginas.cl",
        "description": "Agencia de diseño web profesional en Chile con más de 13 años de experiencia. Especialistas en páginas web con Astro, sitios autoadministrables con WordPress, tiendas online y posicionamiento SEO para empresas chilenas.",
        "url": "https://diseñopaginas.cl/",
        "logo": {
          "@type": "ImageObject",
          "url": "https://diseñopaginas.cl/assets/img/logo-disenopaginas.svg",
          "width": 300,
          "height": 80
        },
        "image": "https://diseñopaginas.cl/assets/img/og-image.jpg",
        "telephone": "+56961765268",
        "email": "codigoraul@gmail.com",
        "foundingDate": "2012",
        "address": {
          "@type": "PostalAddress",
          "addressLocality": "Temuco",
          "addressRegion": "La Araucanía",
          "addressCountry": "CL"
        },
        "areaServed": [
          {
            "@type": "Country",
            "name": "Chile"
          },
          {
            "@type": "City",
            "name": "Santiago"
          },
          {
            "@type": "City",
            "name": "Temuco"
          },
          {
            "@type": "City",
            "name": "Concepción"
          },
          {
            "@type": "City",
            "name": "Valparaíso"
          },
          {
            "@type": "City",
            "name": "Antofagasta"
          },
          {
            "@type": "City",
            "name": "La Serena"
          },
          {
            "@type": "City",
            "name": "Valdivia"
          },
          {
            "@type": "City",
            "name": "Puerto Montt"
          }
        ],
        "serviceType": [
          "Diseño Web",
          "Desarrollo Web con Astro",
          "Sitios Web Autoadministrables",
          "Tiendas Online WooCommerce",
          "Posicionamiento SEO",
          "Diseño de Logotipos",
          "Diseño UX UI en Figma",
          "Mantenimiento Web"
        ],
        "sameAs": [
          "https://www.facebook.com/PaginasChile/",
          "https://www.linkedin.com/in/raul-riquelme-69a16859/",
          "https://www.instagram.com/disenopaginas/",
          "https://www.behance.net/codigoraul",
          "https://www.pinterest.es/boketo11/"
        ],
        "aggregateRating": {
          "@type": "AggregateRating",
          "ratingValue": "5",
          "reviewCount": "10",
          "bestRating": "5",
          "worstRating": "1"
        },
        "numberOfEmployees": {
          "@type": "QuantitativeValue",
          "value": 1
        },
        "knowsAbout": [
          "Diseño Web Profesional",
          "Desarrollo con Astro Framework",
          "WordPress",
          "WooCommerce",
          "SEO Chile",
          "Diseño Gráfico",
          "UX UI Design",
          "Figma"
        ],
        "hasOfferCatalog": {
          "@type": "OfferCatalog",
          "name": "Servicios de Diseño Web",
          "itemListElement": [
            {
              "@type": "Offer",
              "itemOffered": {
                "@type": "Service",
                "name": "Diseño Web con Astro",
                "description": "Páginas web ultrarrápidas desarrolladas con Astro Framework. Puntaje PageSpeed superior a 95/100."
              }
            },
            {
              "@type": "Offer",
              "itemOffered": {
                "@type": "Service",
                "name": "Sitio Web Autoadministrable",
                "description": "Sitios web con WordPress que el cliente puede editar sin conocimientos técnicos."
              }
            },
            {
              "@type": "Offer",
              "itemOffered": {
                "@type": "Service",
                "name": "Tienda Online",
                "description": "Tiendas con WooCommerce con catálogo de productos, carrito de compras y pasarela de pago."
              }
            },
            {
              "@type": "Offer",
              "itemOffered": {
                "@type": "Service",
                "name": "Posicionamiento SEO",
                "description": "Estrategia SEO para aparecer en los primeros resultados de Google en Chile."
              }
            }
          ]
        }
      },
      {
        "@type": "Person",
        "@id": "https://diseñopaginas.cl/#raul",
        "name": "Raúl Riquelme",
        "givenName": "Raúl",
        "familyName": "Riquelme",
        "jobTitle": "Diseñador Web y Desarrollador — Fundador de DiseñoPaginas.cl",
        "description": "Diseñador gráfico y desarrollador web con más de 13 años de experiencia profesional. Especialista en diseño web con Astro, WordPress y posicionamiento SEO para empresas chilenas. Más de 200 proyectos web entregados.",
        "url": "https://diseñopaginas.cl/",
        "email": "codigoraul@gmail.com",
        "telephone": "+56961765268",
        "address": {
          "@type": "PostalAddress",
          "addressLocality": "Temuco",
          "addressRegion": "La Araucanía",
          "addressCountry": "CL"
        },
        "sameAs": [
          "https://www.linkedin.com/in/raul-riquelme-69a16859/",
          "https://twitter.com/raulriquelme2",
          "https://www.behance.net/codigoraul",
          "https://www.instagram.com/disenopaginas/"
        ],
        "knowsAbout": [
          "Diseño Gráfico",
          "Diseño Web",
          "Astro Framework",
          "WordPress",
          "SEO",
          "UX UI Design",
          "Figma",
          "WooCommerce",
          "HTML",
          "CSS"
        ],
        "hasCredential": [
          {
            "@type": "EducationalOccupationalCredential",
            "credentialCategory": "degree",
            "name": "Formación universitaria en Diseño Gráfico y Diseño Web"
          },
          {
            "@type": "EducationalOccupationalCredential",
            "credentialCategory": "certification",
            "name": "Certificaciones Google",
            "recognizedBy": {
              "@type": "Organization",
              "name": "Google"
            }
          }
        ],
        "worksFor": {
          "@id": "https://diseñopaginas.cl/#negocio"
        },
        "founder": {
          "@id": "https://diseñopaginas.cl/#negocio"
        }
      }
    ]
  }
  </script>

  <!-- Schema BreadcrumbList — generado dinámicamente por página -->
  {breadcrumbs && breadcrumbs.length > 0 && (
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Inicio", "item": "https://diseñopaginas.cl/" },
        ...breadcrumbs.map((crumb, i) => ({
          "@type": "ListItem",
          "position": i + 2,
          "name": crumb.name,
          "item": crumb.url
        }))
      ]
    })} />
  )}

  <!-- Schema FAQPage movido a index.astro (solo debe estar en la home, donde el FAQ es visible) -->

</head>

<body>
  <!-- Header -->
  <Header />

  <!-- Main Content -->
  <main>
    <slot />
  </main>

  <!-- Footer -->
  <Footer />

  <!-- Scripts diferidos -->
  <script src={getJsPath('bootstrap.bundle.min.js')} defer></script>
  <script src={getJsPath('swiper-bundle.min.js')} defer></script>
  <script src={getJsPath('wow.min.js')} defer></script>
  <script src={getJsPath('active.js')} defer></script>

  <!-- Jivosite Chat - 4s después para no afectar métricas -->
  <script>
    window.addEventListener('load', function() {
      setTimeout(function() {
        var s = document.createElement('script');
        s.src = '//code.jivosite.com/widget/PgpmFYkQWG';
        s.async = true;
        document.body.appendChild(s);
      }, 4000);
    });
  </script>


</body>
</html>