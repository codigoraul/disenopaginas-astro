          },
          {
            "@type": "City",
            "name": "Puerto Montt"
          }
        ],
        "serviceType": [
          "Diseño Web",
          "Desarrollo Web con Astro",
          "Sitios Web Autoadministrables",
          "Tiendas Online WooCommerce",
          "Posicionamiento SEO",
