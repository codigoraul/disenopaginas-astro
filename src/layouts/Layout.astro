              }
            }
          ]
        }
      },
      {
        "@type": "Person",
        "@id": "https://diseñopaginas.cl/#raul",
        "name": "Raúl Riquelme",
        "givenName": "Raúl",
        "familyName": "Riquelme",
        "jobTitle": "Diseñador Web y Desarrollador — Fundador de DiseñoPaginas.cl",
        "description": "Diseñador gráfico y desarrollador web con más de 13 años de experiencia profesional. Especialista en diseño web con Astro, WordPress y posicionamiento SEO para empresas chilenas. Más de 200 proyectos web entregados.",
        "url": "https://diseñopaginas.cl/",
