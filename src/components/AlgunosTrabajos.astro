<!-- Inicialización del Swiper -->
<script>
  document.addEventListener('DOMContentLoaded', function() {
    new Swiper('.project-swiper', {
      slidesPerView: 1.2,
      spaceBetween: 20,
      loop: true,
      navigation: {
        nextEl: '.project-button-next',
        prevEl: '.project-button-prev',
      },
      breakpoints: {
        576: {
          slidesPerView: 1.8,
          spaceBetween: 20
        },
        768: {
          slidesPerView: 2.2,
          spaceBetween: 25
        },
        992: {
          slidesPerView: 3,
          spaceBetween: 30
        },
        1400: {
          slidesPerView: 4,
          spaceBetween: 30
        }
      },
      autoplay: {
        delay: 3000,
        disableOnInteraction: false,
      },
    });
  });
</script>

<style>
  /* Limitar el ancho de las cards del proyecto */
  .project-swiper-card {
    width: 100%;
    max-width: 100%;
    margin: 0 auto;
    border-radius: 8px !important;
    overflow: hidden;
    height: 100%;
    display: flex;
    flex-direction: column;
  }
  
  /* Estilo para las imágenes del carrusel */
  .project-swiper-card img {
    width: 100%;
    height: 300px;
    object-fit: contain;
    object-position: top;
    background: #f8f9fa;
    display: block;
    border-radius: 8px 8px 0 0 !important;
  }
  
  /* Usar ancho MÁXIMO de la pantalla completa para el portafolio */
  .project-swiper {
    width: 100vw !important;
    margin-left: 0 !important;
    padding: 0 20px;
  }
  
  /* Contenedor fluid para el portafolio */
  .project-section .container-fluid {
    max-width: 100% !important;
    overflow: visible !important;
  }
  
  /* Asegurar que el container normal mantenga su comportamiento */
  .project-section .container {
    max-width: 1200px;
  }
  
  /* Asegurar que las slides se distribuyan correctamente */
  .project-swiper .swiper-wrapper {
    display: flex;
    align-items: stretch;
    padding: 10px 0;
  }
  
  .project-swiper .swiper-slide {
    display: flex;
    height: auto;
    flex-shrink: 0;
    padding: 5px;
  }
  
  /* Ajustes para pantallas grandes */
  @media (min-width: 1400px) {
    .project-swiper .swiper-slide {
      width: calc(100% / 5 - 25px) !important;
    }
  }
  
  /* Ajustes para tablets/notebooks */
  @media (min-width: 992px) and (max-width: 1399px) {
    .project-swiper .swiper-slide {
      width: calc(100% / 4 - 23px) !important;
    }
  }
  
  /* Estilo para los títulos h4 - más pequeños para las cards más pequeñas */
  h4.mb-1 {
    font-size: 1.1rem;
  }
  
  /* Estilo para las URLs - un poco más pequeñas */
  .project-content a {
    font-size: 0.9rem;
    color: #6c757d;
  }
  
  .project-content a:hover {
    color: #011C42;
  }

  .btn-outline-primary:hover,
  .btn-outline-primary:focus {
    color: #ffffff !important;
  }

  .project-button-prev,
  .project-button-next {
    width: 42px !important;
    height: 42px !important;
    min-width: 42px !important;
    min-height: 42px !important;
  }

  .project-button-prev i,
  .project-button-next i {
    font-size: 18px !important;
  }
  
  /* Estilo para el h2 del título principal */
  .section-heading h2 {
    font-size: 36px !important;
  }
  
  /* Ajustar el padding del contenido para las cards más pequeñas */
  .project-content {
    padding: 15px;
  }

  /* MÓVIL: reducir el espacio exagerado entre las flechas y las imágenes */
  @media (max-width: 767px) {
    .project-section .row.align-items-end {
      padding-bottom: 0.5rem !important;
    }
    .project-section .divider-sm {
      height: 0 !important;
      margin: 0 !important;
    }
    .project-swiper .swiper-wrapper {
      padding: 0 0 !important;
    }
  }
</style>